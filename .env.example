# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.

# GitLab personal access token or project access token (read_api scope is sufficient).
# Leave blank to use unauthenticated requests (public repos only, lower rate limits).
GITLAB_TOKEN=

# Base URL of your GitLab instance.  Defaults to https://gitlab.com if not set.
GITLAB_BASE_URL=https://gitlab.com
